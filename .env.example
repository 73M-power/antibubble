# 复制为 .env 并填入你自己的值（.env 已被 .gitignore 忽略，不会泄露）

# 飞书自定义机器人 Webhook（群设置 → 群机器人 → 添加自定义机器人）
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx

# DeepSeek API Key（https://platform.deepseek.com）
DEEPSEEK_API_KEY=sk-xxxxxxxx
# 可选：自定义模型 / 接口地址
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# 可选：自建 RSSHub 实例地址（启用中文源时需要）
# RSSHUB_BASE=https://your-rsshub.example.com

# 可选：Tavily 联网检索 Key（https://tavily.com，有免费额度）
# 填了，反方论证会去搜真实材料取证，卡片标「🔎 反方有据」并附出处；
# 不填，反方为模型纯推理，卡片如实标「💭 请自行核实」。
# TAVILY_API_KEY=tvly-xxxxxxxx
